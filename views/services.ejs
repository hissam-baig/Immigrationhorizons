<section class="section" style="padding-top:48px;">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Services</span>
      <h2>Every category, every deliverable</h2>
      <p>We support EB-2 NIW, EB-1A, EB-1B and EB-1C petitions — as a full end-to-end build, or individual pieces of the process.</p>
    </div>

    <div class="services-grid">
      <% services.forEach(function(s) { %>
        <div class="service-card">
          <div class="service-icon"><%= s.name.slice(0,2) %></div>
          <h3><%= s.name %></h3>
          <span class="tagline"><%= s.tagline %></span>
          <p><%= s.description %></p>
          <a href="/services/<%= s.slug %>" class="learn-more">Learn More →</a>
        </div>
      <% }); %>
    </div>

    <div class="text-center mt-40">
      <a href="/consultation" class="btn btn-primary">Book a Free Consultation</a>
    </div>
  </div>
</section>

<section class="section" style="padding-top:0;">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Marketplace Listings</span>
      <h2>Prefer to book through Fiverr or Upwork?</h2>
      <p>Order the same work as a fixed-scope listing on either platform, with the platform's own buyer protection and messaging.</p>
    </div>

    <div class="gig-card-grid">
      <% marketplaceListings.forEach(function(gig) { %>
        <%- include('partials/gig-card', { gig: gig }) %>
      <% }); %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Landing Pages</span>
      <h2>High-intent pages for search and ads</h2>
      <p>These pages are built for visitors who already know what service they need and are ready to convert.</p>
    </div>

    <div class="services-grid">
      <a class="service-card" href="/eb2-niw">
        <div class="service-icon">E2</div>
        <h3>EB-2 NIW</h3>
        <span class="tagline">National Interest Waiver</span>
        <p>Dedicated landing page for EB-2 NIW search and ad traffic.</p>
      </a>
      <a class="service-card" href="/eb1a">
        <div class="service-icon">E1</div>
        <h3>EB-1A</h3>
        <span class="tagline">Extraordinary Ability</span>
        <p>Dedicated landing page for extraordinary ability petition inquiries.</p>
      </a>
      <a class="service-card" href="/o1-visa">
        <div class="service-icon">O1</div>
        <h3>O-1 Visa</h3>
        <span class="tagline">High-achievement filings</span>
        <p>Dedicated landing page for O-1 visa traffic and consultations.</p>
      </a>
    </div>
  </div>
</section>
