<section class="section" style="padding-top:48px;">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Services</span>
      <h2>Every category, every deliverable</h2>
      <p>We support EB-2 NIW, EB-1A, EB-1B and EB-1C petitions — as a full end-to-end build, or individual pieces of the process.</p>
    </div>

    <div class="services-grid">
      <% services.forEach(function(s) { %>
        <div class="service-card">
          <div class="service-icon"><%= s.name.slice(0,2) %></div>
          <h3><%= s.name %></h3>
          <span class="tagline"><%= s.tagline %></span>
          <p><%= s.description %></p>
          <a href="/services/<%= s.slug %>" class="learn-more">Learn More →</a>
        </div>
      <% }); %>
    </div>

    <div class="text-center mt-40">
      <a href="/consultation" class="btn btn-primary">Book a Free Consultation</a>
    </div>
  </div>
</section>

<section class="section" style="padding-top:0;">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Marketplace Listings</span>
      <h2>Prefer to book through Fiverr or Upwork?</h2>
      <p>Order the same work as a fixed-scope listing on either platform, with the platform's own buyer protection and messaging.</p>
    </div>

    <div class="services-grid" style="max-width:760px;margin:0 auto;">
      <div class="service-card">
        <div class="service-icon" style="background:#1dbf73;color:#fff;">Fi</div>
        <h3>Fiverr Gig</h3>
        <span class="tagline">RFE / NOID Response</span>
        <p>Prepare a tailored response to your RFE from USCIS — order directly through our verified Fiverr profile.</p>
        <a href="<%= fiverrRfeGigUrl %>" target="_blank" rel="noopener" class="learn-more">View Gig on Fiverr →</a>
      </div>
      <div class="service-card">
        <div class="service-icon" style="background:#14a800;color:#fff;">Up</div>
        <h3>Upwork Catalog</h3>
        <span class="tagline">EB-2 NIW RFE Response</span>
        <p>Writing &amp; translation of your RFE response for an EB-2 NIW petition — order directly from our Upwork catalog.</p>
        <a href="<%= upworkRfeNiwCatalogUrl %>" target="_blank" rel="noopener" class="learn-more">View Listing on Upwork →</a>
      </div>
    </div>
  </div>
</section>
