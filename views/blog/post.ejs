<section class="section" style="padding-top:48px;">
  <div class="container">
    <% if (!post) { %>
      <div class="empty-state">
        <h2>Post not found</h2>
        <p>This post may have been removed or unpublished.</p>
        <a href="/blog" class="btn btn-blue">Back to Blog</a>
      </div>
    <% } else { %>
      <div class="post-header">
        <span class="cat"><%= post.category %></span>
        <h1><%= post.title %></h1>
        <p class="meta">By <%= post.author %> · <%= new Date(post.createdAt).toLocaleDateString() %></p>
      </div>

      <% if (post.coverImage) { %>
        <img class="post-cover" src="<%= post.coverImage %>" alt="<%= post.title %>">
      <% } %>

      <div class="post-content">
        <%- post.content %>
      </div>

      <div class="comments-section" id="comments">
        <div class="section-head guides-head">
          <h2><%= comments.length %> Comment<%= comments.length === 1 ? '' : 's' %></h2>
        </div>

        <% if (comments && comments.length) { %>
          <ul class="comment-list">
            <% comments.forEach(function(c) { %>
              <li class="comment">
                <div class="comment-meta">
                  <span class="comment-name"><%= c.name %></span>
                  <span class="comment-date"><%= new Date(c.createdAt).toLocaleDateString() %></span>
                </div>
                <p class="comment-message"><%= c.message %></p>
              </li>
            <% }); %>
          </ul>
        <% } else { %>
          <p>No comments yet. Be the first to share your thoughts.</p>
        <% } %>

        <div class="form-card comment-form-card">
          <% if (typeof commentError !== 'undefined' && commentError) { %>
            <div class="alert alert-error"><%= commentError %></div>
          <% } %>
          <form action="/blog/<%= post.slug %>/comments" method="POST">
            <div class="hp-field" aria-hidden="true">
              <label for="website">Leave this field empty</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
            </div>
            <div class="form-group">
              <label for="comment-name">Name</label>
              <input type="text" id="comment-name" name="name" required maxlength="80" placeholder="Jane Doe">
            </div>
            <div class="form-group">
              <label for="comment-message">Comment</label>
              <textarea id="comment-message" name="message" rows="4" required maxlength="2000" placeholder="Share your thoughts..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Post Comment</button>
          </form>
        </div>
      </div>

      <% if (related && related.length) { %>
        <div class="section-head mt-40">
          <span class="eyebrow">Related Posts</span>
          <h2>More on <%= post.category %></h2>
        </div>
        <div class="blog-grid">
          <% related.forEach(function(r) { %>
            <a class="blog-card" href="/blog/<%= r.slug %>">
              <div class="thumb">
                <% if (r.coverImage) { %><img src="<%= r.coverImage %>" alt="<%= r.title %>"><% } else { %>IH<% } %>
              </div>
              <div class="blog-card-body">
                <span class="cat"><%= r.category %></span>
                <h3><%= r.title %></h3>
                <p><%= r.excerpt %></p>
              </div>
            </a>
          <% }); %>
        </div>
      <% } %>

      <div class="cta-band mt-40">
        <h2>Have a similar case?</h2>
        <p>Book a free consultation and let's talk about your petition.</p>
        <a href="/consultation" class="btn btn-blue">Book Your Free Consultation</a>
      </div>
    <% } %>
  </div>
</section>
