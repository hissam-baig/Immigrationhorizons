# ----- Server -----
PORT=3000
NODE_ENV=development
SITE_URL=https://immigrationhorizons.com

# Bare domain (no https://, no path) that Caddy issues its Let's Encrypt
# certificate for when deploying with docker-compose.prod.yml. Only needed
# for that production/VPS setup - unused in local dev.
SITE_DOMAIN=immigrationhorizons.com

# ----- MongoDB Atlas -----
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# Database Access -> add a user, Network Access -> allow your server's IP (or 0.0.0.0/0)
# Then grab the connection string from "Connect" -> "Drivers"
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/immigration-horizons?retryWrites=true&w=majority

# ----- Session -----
# Any long random string, used to sign the admin login session cookie
SESSION_SECRET=change-this-to-a-long-random-string

# ----- Admin login (blog dashboard at /admin) -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# ----- Resend (for the consultation form emails) -----
# 1. Create a free account at https://resend.com
# 2. Verify a sending domain (or use their shared onboarding@resend.dev sender for testing)
# 3. Create an API key at https://resend.com/api-keys and paste it below
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sender shown on outgoing emails. Must be on a domain you verified in Resend
# (use the default below only for testing - it can't deliver to arbitrary inboxes reliably)
EMAIL_FROM="Immigration Horizons Website <onboarding@resend.dev>"

# Where consultation request emails should be delivered
CONTACT_RECEIVER_EMAIL=smartforce54@gmail.com

# ----- Google Sheets (leads are appended here in addition to the database) -----
# 1. Create a Google Cloud project -> enable the "Google Sheets API"
# 2. IAM & Admin -> Service Accounts -> create one -> Keys -> Add Key -> JSON, download it
# 3. Open your Google Sheet and "Share" it with the service account's email (Editor access)
# 4. Copy the Sheet ID from its URL: https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SERVICE_ACCOUNT_EMAIL=my-service-account@my-project.iam.gserviceaccount.com
# Paste the "private_key" value from the downloaded JSON, keep the \n escape sequences as-is
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxxxxx\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=1AbCDefGhIjKLmNoPQRstuVwxYZ1234567890
# Name of the tab/worksheet within the sheet that leads get appended to (must already exist)
GOOGLE_SHEET_TAB_NAME=Leads

# ----- WhatsApp numbers shown on the site -----
WHATSAPP_NUMBER_1=923305507598
WHATSAPP_NUMBER_2=923418883635

# ----- Analytics / Ads / Tracking -----
GA4_ID=G-XXXXXXXXXX
GTM_ID=GTM-XXXXXXX
META_PIXEL_ID=123456789012345
LINKEDIN_PARTNER_ID=1234567
MICROSOFT_CLARITY_ID=xxxxxxxxxx
